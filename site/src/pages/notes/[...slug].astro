---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getEditNoteUrl } from '../../config';
import { getImportanceBadge, getTypeBadge, getCategoryBadge } from '../../badges';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { title, ticker, type, category, importance, themes, date, stop_loss, sell_trigger } =
  note.data;
const { Content } = await render(note);

const importanceBadge = getImportanceBadge(importance);
const typeBadge = getTypeBadge(type);
const categoryBadge = getCategoryBadge(category);

const dateLabel = new Intl.DateTimeFormat('ko-KR', { dateStyle: 'medium' }).format(date);

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const editUrl = getEditNoteUrl(note.id);
---

<Layout title={`${title} - Equity Universe`}>
  <div class="top-row">
    <a href={base} class="back-link">&larr; 목록으로</a>
    <a href={editUrl} class="edit-link" target="_blank" rel="noopener">GitHub에서 수정/삭제</a>
  </div>

  <article class="note-detail">
    <header>
      <div class="title-row">
        <h1>{title}</h1>
        {ticker && <span class="ticker">{ticker}</span>}
      </div>

      <div class="badges">
        <span class={`badge ${importanceBadge.class}`}>{importanceBadge.label}</span>
        <span class={`badge ${typeBadge.class}`}>{typeBadge.label}</span>
        <span class={`badge ${categoryBadge.class}`}>{categoryBadge.label}</span>
        <span class="badge badge-outline">{dateLabel}</span>
      </div>

      {themes.length > 0 && (
        <div class="themes">
          {themes.map((theme) => (
            <span class="theme-tag">#{theme}</span>
          ))}
        </div>
      )}

      {(stop_loss || sell_trigger) && (
        <div class="meta-box">
          {stop_loss && (
            <p>
              <strong>손절폭:</strong> {stop_loss}
            </p>
          )}
          {sell_trigger && (
            <p>
              <strong>매도 트리거:</strong> {sell_trigger}
            </p>
          )}
        </div>
      )}
    </header>

    <div class="content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent);
    font-weight: 600;
  }

  .edit-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    padding: 4px 14px;
  }

  .edit-link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .note-detail {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .title-row h1 {
    margin: 0;
  }

  .ticker {
    color: var(--color-muted);
    font-size: 1rem;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }

  .themes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }

  .theme-tag {
    font-size: 0.8rem;
    color: var(--color-accent);
    background: #edf2ff;
    border-radius: 6px;
    padding: 2px 8px;
  }

  .meta-box {
    margin-top: 14px;
    padding: 12px 14px;
    background: #f8f9fa;
    border-radius: 8px;
    font-size: 0.9rem;
  }

  .meta-box p {
    margin: 4px 0;
  }

  .content {
    margin-top: 24px;
    line-height: 1.75;
  }

  .content :global(h2) {
    margin-top: 28px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 6px;
  }

  .content :global(ul) {
    padding-left: 1.4em;
  }
</style>

---
interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🏆</text></svg>" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href={base} class="site-title">Equity Universe</a>
      <p class="site-subtitle">주식 아카이브</p>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>내부 공유용 종목 노트입니다.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #f7f7fb;
    --color-card: #ffffff;
    --color-text: #1f2329;
    --color-muted: #6b7280;
    --color-border: #e5e7eb;
    --color-high: #e03131;
    --color-mid: #f08c00;
    --color-low: #868e96;
    --color-accent: #364fc7;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    font-family: "Apple SD Gothic Neo", "Pretendard", "Noto Sans KR", "Malgun Gothic", sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    padding: 24px 16px;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-card);
  }

  .site-title {
    font-size: 1.6rem;
    font-weight: 800;
  }

  .site-subtitle {
    margin: 4px 0 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px 16px 64px;
  }

  .site-footer {
    text-align: center;
    padding: 24px 16px;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  /* 공통 뱃지 스타일 */
  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
  }

  .badge-high {
    background: var(--color-high);
  }

  .badge-mid {
    background: var(--color-mid);
  }

  .badge-low {
    background: var(--color-low);
  }

  .badge-outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .badge-accent {
    background: var(--color-accent);
  }

  .badge-warn {
    background: #fff3bf;
    color: #5c3c00;
    border: 1px solid #ffd43b;
  }
</style>
